PORT=5000
# Local MongoDB (default):
# MONGO_URI=mongodb://127.0.0.1:27017/student_grievance_db

# MongoDB Atlas (Render/Cloud):
# If password contains special characters, URL-encode it.
MONGO_URI=mongodb+srv://<db_user>:<url_encoded_password>@<cluster-host>/<database>?retryWrites=true&w=majority&appName=<app-name>
JWT_SECRET=your_super_secret_key
